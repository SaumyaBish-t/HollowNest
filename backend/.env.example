# ── Database (Neon Postgres) — REQUIRED ──
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/neondb

# ── Workspace where agent reads/writes files ──
WORKSPACE_DIR=/tmp/agent_workspace

# ── CORS — comma-separated origins for the deployed frontend ──
# Vercel *.vercel.app is auto-allowed. Add custom domain here.
CORS_ORIGINS=https://your-frontend.vercel.app

# ── LLM providers — fill at least one ──
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
NVIDIA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DASHSCOPE_API_KEY=
MISTRAL_API_KEY=
OLLAMA_API_KEY=

# ── External tools — optional ──
TAVILY_API_KEY=
GITHUB_TOKEN=
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=HollowNest Agent
NOTION_API_KEY=
SLACK_WEBHOOK_URL=

DEFAULT_PROVIDER=qwen

# ── Clerk authentication — REQUIRED in production ──
# CLERK_JWT_ISSUER is your Clerk Frontend API URL. Find it in the Clerk
# Dashboard under API Keys → "Frontend API URL". Looks like:
#   https://your-app.clerk.accounts.dev   (dev instance)
#   https://clerk.yourdomain.com          (production)
CLERK_JWT_ISSUER=
# Local-dev escape hatch. Set to true to skip token verification (every
# request is treated as the same pseudo user). Never enable in production.
CLERK_DISABLE_AUTH=false
